<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    
    <title>Benno Vertretungsplan</title>
    <link href="https://www.benno-gymnasium.de/favicon.ico" rel="icon">

    <script>
        setInterval(() => {
            location.reload();
        }, {{ cfg.updatecycle }} * 60 * 1000);
    </script>

</head>
<body>
    <div id="header-section">
        <div class="ticker-wrapper">
            <div class="ticker">
                {{ "  +++  ".join(cfg.content.ticker) }}
            </div>
        </div>
    </div>
    
    <div id="content-section">
        <div id="plan-section">
            <div id="content-scroller">

                {# Unter- & Mittelstufe #}
                <div class="plan-wrapper">
                    {% for klasse in vp.klassen.values()
                        if klasse.kürzel in cfg.content.klassen
                        and (not cfg.content.nuränderungen or (klasse.stunden.values() | sum(start=[]) | selectattr('geändert') | list | length > 0))
                    %}
                        <div class="klasse">
                            <div class="klassenkürzel">{{ klasse.kürzel }}</div>
                            <div class="perioden-wrapper">
                                {% for periode, stunden in klasse.stunden.items()
                                    if not cfg.content.nuränderungen
                                    or (stunden | selectattr('geändert') | list | length > 0)
                                %}
                                    <div class="periode">
                                        <div class="periode-zahl">{{ periode }}</div>
                                        <div class="stunden-wrapper">
                                            {% for stunde in klasse.stunden[periode] if (not cfg.content.nuränderungen) or stunde.geändert %}
                                                <div class="stunde">
                                                    <div class="stunden-flr">
                                                            <span class="fach {% if stunde.fachgeändert %}änderung{% endif %}">
                                                                {{ (stunde.fach or (klasse.kurse[stunde.kursnummer].kürzel if stunde.kursnummer in klasse.kurse else '') or '').replace("Fördern", "Fö") }}
                                                            </span>
                                                        {% if not stunde.ausfall %}
                                                            <span class="lehrer {% if stunde.lehrergeändert %}änderung{% endif %}">{{ ", ".join(stunde.lehrer)}}</span>
                                                            <span class="raum {% if stunde.raumgeändert %}änderung{% endif %}">{{ ", ".join(stunde.räume) }}</span>
                                                        {% else %}
                                                            <span class="änderung">Ausfall</span>
                                                        {% endif %}
                                                    </div>
                                                    {% if stunde.info is not none %}<div class="stundeninfo">{{ stunde.info }}</div>{% endif %}
                                                </div>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# Oberstufe #}
                <div class="plan-wrapper detailed">
                    {% for klasse in vp.klassen.values() if klasse.kürzel in cfg.content.klassendetailiert %}
                    <div class="klasse">
                        <div class="klassenkürzel">{{ klasse.kürzel }}</div>
                        <div class="perioden-wrapper">
                            {% for periode, stunden in klasse.stunden.items()
                                if not cfg.content.nuränderungen
                                or (stunden | selectattr('geändert') | list | length > 0)
                            %}
                            <div class="periode">
                                <div class="periode-zahl">{{ periode }}</div>
                                <div class="stunden-wrapper">
                                    {% for stunde in sort_stunden_by_fach(klasse.stunden[periode]) if (not cfg.content.nuränderungen) or stunde.geändert %}
                                    <div class="stunde">
                                        <div class="stunden-flr">
                                                <span class="fach{% if stunde.fachgeändert %} änderung{% endif %}">{{ stunde.fach or klasse.kurse[stunde.kursnummer].kürzel or ""}}</span>
                                            {% if not stunde.ausfall %}
                                                <span class="lehrer{% if stunde.lehrergeändert %} änderung{% endif %}">{{ ",".join(stunde.lehrer)}}</span>
                                                <span class="raum{% if stunde.raumgeändert %} änderung{% endif %}">{{ ",".join(stunde.räume) }}</span>
                                            {% else %}
                                                <span class="änderung">Ausfall</span>
                                            {% endif %}
                                        </div>
                                        {% if stunde.info is not none %}<div class="stundeninfo">{{ stunde.info }}</div>{% endif %}
                                    </div>
                                    {% endfor %}
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            <div id="footer-section">
                <div class="ticker-wrapper">
                    <div class="ticker">
                        {{ (vp.zusatzInfo or "").replace('\n', ' +++ ').replace('\r\n', ' +++ ') }}
                    </div>
                </div>
            </div>
        </div>
        <div id="sidebar-section" {% if not cfg.content.sidebar %}style="display: none;"{% endif %}>
            <div class="sidebar-container" style="background-image: url('{{ url_for('static', filename='logo.svg') }}') ">
                <div id="clock">
                    <span id="time"></span>
                    <span id="date"></span>
                </div>
                <div id="solardaten">
                    <div class="solarheader">Solaranlage</div>
                    <span id="ertrag">{{ sol.EnergieErtragGesamt }} erzeugt</span>
                    <span id="ertrag">{{ sol.CO2EinsparungGesamt }} CO2 eingespart</span>
                </div>
            </div>
            <div id="watermark"><p>Werbunk</p></div>
        </div>

    </div>

{# Clock #}
<script>
  function updateDateTime() {
    const now = new Date();

    const date = now.toLocaleDateString('de-DE', {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric'
    });

    const time = now.toLocaleTimeString('de-DE', {
      hour: '2-digit',
      minute: '2-digit'
    });

    document.getElementById('date').textContent = date;
    document.getElementById('time').textContent = time;
  }

  updateDateTime();
  setInterval(updateDateTime, 1000);
</script>

{# Auto-Scroller #}
<script> 
    const container = document.getElementById("content-scroller");
    const speed = {{ cfg.content.scrolling.pixels }};
    const interval = {{ cfg.content.scrolling.interval }} * 1000;

    let isScrolling = true;

    function autoScroll() {
        if (!isScrolling) return;

        container.scrollTop += speed;

        if (container.scrollTop + container.clientHeight >= container.scrollHeight) {
            isScrolling = false;
            setTimeout(() => {
                container.scrollTop = 0;
                setTimeout(() => {
                    isScrolling = true;
                }, 3000);
            }, 1800);
        }
    }

    {% if not cfg.dev %}
    setInterval(autoScroll, interval);
    {% endif %}
</script>

{# Ticker #}
<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".ticker-wrapper").forEach((wrapper) => {
            const ticker = wrapper.querySelector(".ticker");
            if (!ticker) return;

            const text = ticker.innerHTML.trim();

            ticker.innerHTML = `
            <span class="ticker-item">${text}</span>
            <span class="ticker-item" aria-hidden="true">${text}</span>
            `;

            const width = ticker.scrollWidth;
            const speed = 160; // px pro Sekunde
            ticker.style.setProperty("--duration", `${Math.max(width / speed, 8)}s`);
        });
    });
</script>

</body>
</html>